# ----------------------------------------------------------------------------
# ZELOCORECMS - Git Ignore Configuration
# ----------------------------------------------------------------------------

# 1. Environment & Secrets
.env
.env.*            # ignore all env variants
.env.backup
.env.production
.env.testing
/auth.json
*.key
*.pem
*.secret

# 2. Dependencies
/vendor/
/node_modules/
npm-debug.log*
yarn-error.log*
yarn.log

# 3. Laravel Framework & Storage
/bootstrap/cache/
/public/build
/public/hot
/public/storage
/storage/app/
/storage/framework/
/storage/logs/
/storage/pail
/storage/debugbar/
*.sqlite
*.sqlite-journal

# 4. IDE / Editor / OS
.DS_Store
Thumbs.db
_ide_helper.php
_ide_helper_models.php
/.idea/
/*.iml
.vscode/
*.sublime-workspace
*.sublime-project

# 5. Testing & Coverage
phpunit.xml.local
.phpunit.result.cache
/coverage/

# 6. Vagrant / Homestead / Virtualization
Homestead.json
Homestead.yaml
/.vagrant/

# 7. Logs & Temp
*.log
*.cache
tmp/
temp/

# ----------------------------------------------------------------------------
# AI / Assistant / Dot-folder global exclusion
# ----------------------------------------------------------------------------
/.agents
/.amp
/.claude
/.cmsplan
/.cursor
/.editorconfig
/.env*
/.factory
/.gitattributes
