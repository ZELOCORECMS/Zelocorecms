# ----------------------------------------------------------------------------
# ZELOCORECMS - Git Ignore Configuration
# ----------------------------------------------------------------------------

# 1. Environment & Secrets
.env
.env.backup
.env.production
.env.testing
/auth.json
*.key

# 2. Dependencies
/vendor/
/node_modules/
npm-debug.log
yarn-error.log
yarn.log

# 3. Laravel Framework & Storage
/bootstrap/cache/
/public/build
/public/hot
/public/storage
/storage/app/
/storage/framework/
/storage/logs/
/storage/pail
/storage/debugbar/
*.sqlite
*.sqlite-journal

# 4. OS & IDE Junk
.DS_Store
Thumbs.db
_ide_helper.php
_ide_helper_models.php

# 5. Testing & Profiling
/phpunit.xml
/coverage/

# 6. Vagrant / Homestead
Homestead.json
Homestead.yaml

# 7. Logs & Temp
*.log

# ----------------------------------------------------------------------------
# DOT-FOLDER GLOBAL EXCLUSION
# ----------------------------------------------------------------------------
# Ignore all hidden folders by default
.*/

# ----------------------------------------------------------------------------
# EXPLICIT INCLUSIONS (Crucial folders we force Git to track)
# ----------------------------------------------------------------------------
# 1. Project config
!.github/

# 2. CMS Planning
!/.cmsplan/
